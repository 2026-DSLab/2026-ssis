# 국가법령정보 Open API / MySQL (필수)
LAW_API_OC=발급받은_OC_인증키
MYSQL_PASSWORD=MySQL_비밀번호

# MySQL (선택)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_DATABASE=law_tracking_db

# OpenRouter 요약 (키를 넣으면 기본적으로 활성화)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter 모델 ID는 공급자/모델 형식입니다. 예: openai/gpt-4o-mini
OPENAI_MODEL=openai/gpt-4o-mini
# 키가 있으면 자동 활성화됩니다. 명시적으로 끄거나 켤 때만 설정하세요.
# OPENAI_SUMMARY_ENABLED=true
OPENAI_SUMMARY_REQUIRED=false
OPENAI_TIMEOUT=120
OPENAI_MAX_RETRIES=2
OPENAI_MAX_INPUT_CHARS=180000

# 독립 검증 에이전트
# 요약 모델과 같은 OpenRouter 키/연결을 사용하며 모델만 별도로 지정할 수 있습니다.
OPENAI_VERIFY_ENABLED=true
OPENAI_VERIFY_REQUIRED=true
OPENAI_VERIFY_FAIL_CLOSED=true
# 비워 두면 OPENAI_MODEL을 그대로 사용합니다.
OPENAI_VERIFY_MODEL=
OPENAI_VERIFY_MAX_INPUT_CHARS=180000

# 기타
EXPORT_DIR=out
CONTRACT_VERSION=1.0
LOG_LEVEL=INFO
